# Copy to .env and adjust for your car. All values are optional; the defaults
# shown here match the original hardware setup.

# --- Web server ---
RC_HOST=0.0.0.0
RC_PORT=8080
# Shared secret for /ws and /stream. STRONGLY recommended when exposed over 4G.
# Leave empty to disable auth. Example: RC_AUTH_TOKEN=change-me-please
RC_AUTH_TOKEN=

# --- Arduino / motors ---
RC_SERIAL_PORT=/dev/ttyACM0
# Must match Serial.begin() in the firmware.
RC_SERIAL_BAUD=115200

# --- Camera ---
# auto | picamera2 | opencv | mock
RC_CAMERA_SOURCE=auto
RC_CAMERA_DEVICE=0
RC_CAMERA_WIDTH=640
RC_CAMERA_HEIGHT=480
RC_CAMERA_FPS=15
RC_CAMERA_QUALITY=70

# --- Safety ---
# Stop the car if no command arrives within this many seconds (0 = disabled).
RC_SAFETY_TIMEOUT=1.5

# Force mock hardware everywhere (handy for development off the Pi).
RC_MOCK=0
